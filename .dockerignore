# Build-context excludes for deploy/Dockerfile.{api,web} (context = repo root).
# Keep the context small/fast and force a clean dependency install in the images.
.git
.gitignore
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
api/.venv
api/.pytest_cache
web/node_modules
web/.next
web/test-results
web/playwright-report
web/coverage
web/.turbo
node_modules
**/.DS_Store
.claude
.agents
.codex
.cursor
.gemini
.operator
.benchmarks
.skillmeat
docs
Artifact_Atlas_PRD_UIUX_Implementation_Spec_Package
fixtures/perf
