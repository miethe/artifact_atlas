# Artifact Atlas — web (Next.js 15 / React 19) production image.
#
# Single-stage: install → build → `next start`. next.config.mjs does not set
# `output: standalone`, so we keep node_modules + .next and serve via next start.
#
# IMPORTANT: NEXT_PUBLIC_API_BASE_URL is INLINED AT BUILD TIME (next.config.mjs
# `env`). It must be the *browser-reachable* API URL — i.e. the agentic node's LAN
# host:port (e.g. http://10.42.10.76:8042), not an in-network compose service name,
# because the data fetches run client-side. docker-compose.yml passes it as a build
# arg sourced from deploy/.env.
FROM node:22-bookworm-slim

ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /app/web

# Dependency layer — cache on the lockfile. `@miethe/ui` resolves from public npm
# (registry.npmjs.org), so no registry auth / .npmrc is required. Install includes
# devDependencies (tailwind/postcss/typescript) which `next build` needs, so we do
# NOT set NODE_ENV=production before `npm ci`.
COPY web/package.json web/package-lock.json ./
RUN npm ci

# App source + production build. `npm run build` runs the prebuild step
# (copy-pdf-worker.mjs) then `next build`.
COPY web ./
ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:8042
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
RUN npm run build

EXPOSE 3040
CMD ["npm", "run", "start", "--", "-H", "0.0.0.0", "-p", "3040"]
