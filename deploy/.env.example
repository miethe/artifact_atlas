# Artifact Atlas deploy — env knobs consumed by deploy/docker-compose.yml.
#
# The agentic-node bootstrap (bootstrap-agentic-node.sh ph_artifact_atlas) writes the
# real deploy/.env with the node's values. Copy this file to deploy/.env for a manual
# run. Compose reads it via `--env-file deploy/.env`.

# Host interface to publish on (0.0.0.0 = LAN-reachable; 127.0.0.1 = loopback-only).
ATLAS_BIND_HOST=127.0.0.1

# Published host ports (container ports are fixed at 3040/8042).
ATLAS_WEB_PORT=3040
ATLAS_API_PORT=8042

# Browser-reachable API base URL, INLINED INTO THE WEB BUILD. Must be the host:port
# the *browser* can reach — on the LAN node: http://<node-ip>:8042 (e.g.
# http://10.42.10.76:8042). For a loopback run: http://localhost:8042.
ATLAS_WEB_API_BASE_URL=http://localhost:8042

# Comma-separated origins the API allows via CORS (the web origin the browser loads
# from). On the LAN node: http://<node-ip>:3040.
ATLAS_CORS_ORIGINS=http://localhost:3040
